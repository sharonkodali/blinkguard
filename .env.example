# Copy to .env.local and fill in values. Restart `npm run dev` after changes.

ANTHROPIC_API_KEY=

# Browser map + routing (Monitor page). Enable on this key:
# - Maps JavaScript API
# - Directions API (required for Navigate — does not use legacy Places Autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server-side Places (nearby stops). Can be the same key as above if APIs are enabled.
GOOGLE_PLACES_API_KEY=

# Optional fallbacks (only if you do not set GOOGLE_PLACES_API_KEY):
# GOOGLE_MAPS_API_KEY=
