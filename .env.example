# Copy to .env.local and fill in values. Restart `npm run dev` after changes.

ANTHROPIC_API_KEY=

# Browser map (Monitor page). Restrict to http://localhost:3000/* referrers in Cloud Console.
# Enable: Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server: Routes API (POST /api/maps/compute-route). This request runs on Next.js, NOT in the browser,
# so keys restricted to "HTTP referrers" will be BLOCKED. Use a separate key with:
# - Application restrictions: None (local dev) or IP addresses (production)
# - API restrictions: include "Routes API" (and any others this key needs)
GOOGLE_ROUTES_API_KEY=

# Server-side Places (nearby stops). Can match GOOGLE_ROUTES_API_KEY if that key also has Places API (New).
GOOGLE_PLACES_API_KEY=

# Optional alias for server-side Maps/Routes if you do not use GOOGLE_ROUTES_API_KEY:
# GOOGLE_MAPS_API_KEY=

# ── Fetch.ai safety agent ──────────────────────────────────────────────
# URL of the SafetyOrchestratorAgent REST endpoint (agents/safety_service.py).
# If unreachable, /api/safety transparently falls back to the TS mock
# engine in lib/safety-logic.ts so the demo keeps working.
SAFETY_AGENT_URL=http://127.0.0.1:8100/telemetry
